{
  "manifest_version": 3,
  "name": "TARS Browser Relay Bridge",
  "description": "Experimental extension bridge for the local TARS browser relay.",
  "version": "0.1.0",
  "permissions": [
    "debugger",
    "storage",
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*",
    "ws://127.0.0.1/*",
    "ws://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "TARS Relay"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
