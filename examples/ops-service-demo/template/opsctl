#!/bin/sh
set -eu

ROOT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd)
COMPOSE_FILE="${OPSCTL_COMPOSE_FILE:-$ROOT_DIR/docker-compose.yml}"
SERVICE_NAME="${OPSCTL_SERVICE_NAME:-ops-service}"
BASE_URL="${OPSCTL_BASE_URL:-http://127.0.0.1:18080}"
TAIL_LINES="${OPSCTL_LOG_TAIL:-120}"

compose() {
  docker compose -f "$COMPOSE_FILE" "$@"
}

usage() {
  cat <<'EOF'
usage: ./opsctl <command> [args]

commands:
  status                 show docker compose status and current health payload
  health                 fetch /healthz payload
  logs [tail]            show recent service logs
  errors [tail]          filter recent error logs
  restart                restart the demo service
  inject-failure <mode>  set failure mode: timeout | http500
  clear-failure          clear the injected failure mode
EOF
}

require_cmd() {
  if ! command -v "$1" >/dev/null 2>&1; then
    printf 'missing required command: %s\n' "$1" >&2
    exit 1
  fi
}

status_cmd() {
  require_cmd docker
  require_cmd curl
  compose ps
  printf '\n'
  curl -sS "$BASE_URL/healthz" || true
  printf '\n'
}

health_cmd() {
  require_cmd curl
  curl -sS "$BASE_URL/healthz"
  printf '\n'
}

logs_cmd() {
  require_cmd docker
  tail_lines="${1:-$TAIL_LINES}"
  compose logs --tail "$tail_lines" "$SERVICE_NAME"
}

errors_cmd() {
  require_cmd docker
  tail_lines="${1:-$TAIL_LINES}"
  compose logs --tail "$tail_lines" "$SERVICE_NAME" | grep '"level":"error"' || true
}

restart_cmd() {
  require_cmd docker
  compose restart "$SERVICE_NAME"
}

inject_failure_cmd() {
  require_cmd curl
  mode="${1:-}"
  if [ -z "$mode" ]; then
    printf 'inject-failure requires a mode: timeout | http500\n' >&2
    exit 1
  fi
  curl -sS -X POST "$BASE_URL/admin/failure?mode=$mode"
  printf '\n'
}

clear_failure_cmd() {
  require_cmd curl
  curl -sS -X POST "$BASE_URL/admin/failure/clear"
  printf '\n'
}

cmd="${1:-}"
case "$cmd" in
  status)
    shift
    status_cmd "$@"
    ;;
  health)
    shift
    health_cmd "$@"
    ;;
  logs)
    shift
    logs_cmd "$@"
    ;;
  errors)
    shift
    errors_cmd "$@"
    ;;
  restart)
    shift
    restart_cmd "$@"
    ;;
  inject-failure)
    shift
    inject_failure_cmd "$@"
    ;;
  clear-failure)
    shift
    clear_failure_cmd "$@"
    ;;
  ""|-h|--help|help)
    usage
    ;;
  *)
    printf 'unknown command: %s\n\n' "$cmd" >&2
    usage >&2
    exit 1
    ;;
esac
