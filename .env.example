# tars runtime defaults
TARS_MODE=standalone
TARS_WORKSPACE_DIR=./workspace
API_ADDR=127.0.0.1:43180

# -------------------------------------------------------------------
# LLM provider settings
# 한 번에 하나의 provider 조합만 사용하세요.
# -------------------------------------------------------------------

# Option A) OpenAI API key (권장)
LLM_PROVIDER=openai
LLM_AUTH_MODE=api-key
OPENAI_API_KEY=sk-...
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Option B) Anthropic API key
# LLM_PROVIDER=anthropic
# LLM_AUTH_MODE=api-key
# ANTHROPIC_API_KEY=...
# LLM_BASE_URL=https://api.anthropic.com
# LLM_MODEL=claude-3-5-haiku-latest

# Option C) Gemini OpenAI-compatible
# LLM_PROVIDER=gemini
# LLM_AUTH_MODE=api-key
# GEMINI_API_KEY=...
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# LLM_MODEL=gemini-2.5-flash

# Option D) Gemini native API
# LLM_PROVIDER=gemini-native
# LLM_AUTH_MODE=api-key
# GEMINI_API_KEY=...
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# LLM_MODEL=gemini-2.5-flash

# Option E) Bifrost gateway
# LLM_PROVIDER=bifrost
# LLM_AUTH_MODE=api-key
# BIFROST_BASE_URL=http://127.0.0.1:8080/v1
# BIFROST_API_KEY=your-bifrost-key
# BIFROST_MODEL=openai/gpt-4o-mini

# -------------------------------------------------------------------
# Optional: API auth tokens
# -------------------------------------------------------------------
# API_AUTH_MODE=required
# API_USER_TOKEN=replace-user-token
# API_ADMIN_TOKEN=replace-admin-token
# API_ALLOW_INSECURE_LOCAL_AUTH=false
# API_MAX_INFLIGHT_CHAT=2
# API_MAX_INFLIGHT_AGENT_RUNS=4

# -------------------------------------------------------------------
# Optional: Browser + Vault automation
# -------------------------------------------------------------------
# VAULT_ENABLED=false
# VAULT_ADDR=http://127.0.0.1:8200
# VAULT_AUTH_MODE=token
# VAULT_TOKEN=
# VAULT_KV_MOUNT=tars
# VAULT_KV_VERSION=2
# VAULT_SECRET_PATH_ALLOWLIST_JSON=["sites/"]
# BROWSER_RUNTIME_ENABLED=true
# BROWSER_RELAY_ENABLED=true
# BROWSER_RELAY_ADDR=127.0.0.1:43182
# BROWSER_RELAY_ALLOW_QUERY_TOKEN=false
# BROWSER_AUTO_LOGIN_SITE_ALLOWLIST_JSON=["grafana"]
# TOOLS_ALLOW_HIGH_RISK_USER=false
# PLUGINS_ALLOW_MCP_SERVERS=false
# MCP_COMMAND_ALLOWLIST_JSON=["npx"]

# -------------------------------------------------------------------
# NOTE
# -------------------------------------------------------------------
# Removed providers (no longer supported):
# - codex-cli
# - openai-codex
# LLM_PROVIDER=openai
# LLM_AUTH_MODE=api-key
# OPENAI_API_KEY=sk-...
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# Option C) Bifrost gateway
# LLM_PROVIDER=bifrost
# LLM_AUTH_MODE=api-key
# BIFROST_BASE_URL=http://bifrost.orb.local/v1
# BIFROST_API_KEY=your-bifrost-key
# BIFROST_MODEL=openai/gpt-4o-mini

# Option D) Anthropic API key
# LLM_PROVIDER=anthropic
# LLM_AUTH_MODE=api-key
# ANTHROPIC_API_KEY=...
# LLM_BASE_URL=https://api.anthropic.com
# LLM_MODEL=claude-3-5-haiku-latest
