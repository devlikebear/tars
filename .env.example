# tarsd runtime defaults
TARSD_MODE=standalone
TARSD_WORKSPACE_DIR=./workspace

# -------------------------------------------------------------------
# LLM provider settings
# 한 번에 하나의 provider 조합만 사용하세요.
# -------------------------------------------------------------------

# Option A) Codex CLI subprocess (권장: codex login 후 사용)
LLM_PROVIDER=codex-cli
LLM_MODEL=gpt-5.3-codex
# Optional: codex binary path override
# CODEX_CLI_BIN=/usr/local/bin/codex

# Option B) OpenAI API key
# LLM_PROVIDER=openai
# LLM_AUTH_MODE=api-key
# OPENAI_API_KEY=sk-...
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# Option C) Bifrost gateway
# LLM_PROVIDER=bifrost
# LLM_AUTH_MODE=api-key
# BIFROST_BASE_URL=http://bifrost.orb.local/v1
# BIFROST_API_KEY=your-bifrost-key
# BIFROST_MODEL=openai/gpt-4o-mini

# Option D) Anthropic API key
# LLM_PROVIDER=anthropic
# LLM_AUTH_MODE=api-key
# ANTHROPIC_API_KEY=...
# LLM_BASE_URL=https://api.anthropic.com
# LLM_MODEL=claude-3-5-haiku-latest
